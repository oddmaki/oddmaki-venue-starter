# Venue Configuration
NEXT_PUBLIC_VENUE_ID=


NEXT_PUBLIC_VENUE_NAME=

# Chain Configuration
#NEXT_PUBLIC_CHAIN_ID=8453  # Base mainnet
#NEXT_PUBLIC_CHAIN_ID=84532  # Base Sepolia
NEXT_PUBLIC_CHAIN_ID=

# The Graph gateway API key.
# Optional locally (SDK falls back to a free, rate-limited Studio endpoint).
# Set this in your production environment for the decentralized gateway.
# Get one for free: https://thegraph.com/studio → API Keys → Create API Key
# Add your production domain(s) under the key's Authorized Domains and set a
# monthly spending cap before deploying. See README → "Subgraph data".
NEXT_PUBLIC_GRAPH_API_KEY=

# RainbowKit (default, crypto-native) or Privy for consumer-friendly
# RainbowKit is Free.
# Privy has a Free tier but it's paid once scaling up.
NEXT_PUBLIC_AUTH_PROVIDER=rainbowkit

# Privy (consumer-friendly)
#NEXT_PUBLIC_AUTH_PROVIDER=privy
#NEXT_PUBLIC_PRIVY_APP_ID=your-app-id

# IPFS
PINATA_JWT="pinata-jwt"
NEXT_PUBLIC_IPFS_GATEWAY="https://gateway.pinata.cloud/ipfs/"


NEXT_PUBLIC_ENABLE_THEME_EDITOR=true
