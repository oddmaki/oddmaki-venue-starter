# Venue Configuration
NEXT_PUBLIC_VENUE_ID=0
NEXT_PUBLIC_VENUE_NAME="OddMaki Venue"

# Chain Configuration
#NEXT_PUBLIC_CHAIN_ID=8453  # Base mainnet
#NEXT_PUBLIC_CHAIN_ID=84532  # Base Sepolia
NEXT_PUBLIC_CHAIN_ID=8453 # Base

# Features
NEXT_PUBLIC_ENABLE_MARKET_CREATION=false

# RainbowKit (default, crypto-native) or Privy for consumer-friendly
# RainbowKit is Free.
# Privy has a Free tier but it's paid once scaling up.
NEXT_PUBLIC_AUTH_PROVIDER=rainbowkit

# Privy (consumer-friendly)
#NEXT_PUBLIC_AUTH_PROVIDER=privy
#NEXT_PUBLIC_PRIVY_APP_ID=your-app-id

# IPFS
PINATA_JWT="pinata-jwt"
NEXT_PUBLIC_IPFS_GATEWAY="https://gateway.pinata.cloud/ipfs/"


NEXT_PUBLIC_ENABLE_THEME_EDITOR=true
